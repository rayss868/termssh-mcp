// Example local MCP config for development/testing.
// You can use either direct CLI credentials or the recommended vault mode.
{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "termssh-mcp-server": {
      "type": "local",
      "command": [
        "node",
        "build/index.js",
        "--vault=./termssh-mcp-vault.json",
        "--timeout=60000"
      ],
      "enabled": true,
    },
  },
}
