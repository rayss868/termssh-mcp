// Example local MCP config for development/testing.
// Recommended: use vault mode and pass `account` in MCP tool calls.
// If `account` is omitted, runtime now rejects the tool call and asks for an explicit account choice.
{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "termssh-mcp-server": {
      "type": "local",
      "command": [
        "node",
        "build/index.js",
        "--vault=./termssh-mcp-vault.json",
        "--timeout=60000"
      ],
      "enabled": true,
    },
  },
}
